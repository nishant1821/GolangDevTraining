# Copy this file to .env and fill in values for local development.
# Production values should come from a secrets manager (Vault, AWS SSM, etc.)
# Never commit .env to git — add it to .gitignore.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgres://pulse:pulse@localhost:5432/pulse?sslmode=disable

# ── Cache (Redis) ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
# IMPORTANT: change this to a long random string in production!
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRY_HOURS=24

# ── Worker Pool ──────────────────────────────────────────────────────────────
WORKER_COUNT=10
CHECK_TIMEOUT_SECONDS=10
SCHEDULE_INTERVAL_SECONDS=30
